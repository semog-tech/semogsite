# Semog · Next.js + Payload — variáveis de ambiente (Plano 1: fundação + dados)
#
# Copie este arquivo para `.env` e preencha com as credenciais do projeto Supabase.
# Nunca commite `.env` (já está no .gitignore).
#
# ARQUITETURA DE DADOS (decidido): o CMS usa o projeto Supabase EXISTENTE `semog`
# (ref qvxlkovrxfqigeaopvui, região us-east-2), mas num **schema dedicado `cms`**
# (já criado), isolado de public/auth/storage do webapp. Uploads vão num **bucket
# dedicado `media`**. As chaves S3 do Supabase são do projeto inteiro — trate-as
# como sensíveis.
#
# Postgres (Supabase):
# - DATABASE_URI        → use o **Session pooler** (porta 5432). Conexão de runtime;
#                          suporta prepared statements, que o adapter Postgres do
#                          Payload (Drizzle) exige. Copie a string EXATA do dashboard:
#                          Connect → Session pooler (confirme o host aws-*-us-east-2).
# - DATABASE_URI_DIRECT → conexão **Direct** (host db.<ref>.supabase.co), usada apenas
#                          para rodar migrations (Task 6).
# - O **Transaction pooler (porta 6543) é proibido**: não suporta prepared statements
#   e quebra o adapter Postgres do Payload.

# Supabase Postgres — Session pooler (app) — troque só <password>; confirme o host no Connect
DATABASE_URI=postgresql://postgres.qvxlkovrxfqigeaopvui:<password>@aws-0-us-east-2.pooler.supabase.com:5432/postgres

# Supabase Postgres — Direct connection (migrations) — troque só <password>
DATABASE_URI_DIRECT=postgresql://postgres:<password>@db.qvxlkovrxfqigeaopvui.supabase.co:5432/postgres

# Payload — gerar com: openssl rand -base64 32
PAYLOAD_SECRET=

# Supabase Storage (S3-compatible) — uploads da collection `media` (bucket dedicado)
# Crie o bucket `media` (público) e gere as S3 Access Keys em: Storage → S3 Access Keys.
S3_BUCKET=media
S3_REGION=us-east-2
S3_ENDPOINT=https://qvxlkovrxfqigeaopvui.supabase.co/storage/v1/s3
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
SUPABASE_STORAGE_PUBLIC_URL=https://qvxlkovrxfqigeaopvui.supabase.co/storage/v1/object/public

# SEO (Plano 4a) — base pras URLs absolutas (canonical/OpenGraph/JSON-LD) em `src/lib/seo.ts`.
# Opcional: sem isso, cai no fallback 'https://www.semog.com.br' embutido no código.
NEXT_PUBLIC_SITE_URL=https://www.semog.com.br

# E-mail transacional (Plano 4b) — `src/lib/sendgrid.ts` envia as notificações de
# formulário (interna + auto-reply pro lead, templates em `src/emails/`) via SendGrid.
# SEM `SENDGRID_API_KEY`: o envio é um no-op logado (`console.info`) — a submissão do
# formulário continua funcionando normalmente, só não sai e-mail. Preencha as 3
# variáveis abaixo quando a conta/chave do SendGrid estiver disponível.
# SENDGRID_API_KEY  → gerada em app.sendgrid.com (Settings → API Keys).
# SENDGRID_FROM     → remetente verificado no SendGrid (Sender Authentication), ex.:
#                      no-reply@semog.com.br.
# CONTACT_TO        → caixa de entrada que recebe a notificação interna de cada lead.
SENDGRID_API_KEY=
SENDGRID_FROM=
CONTACT_TO=

# Cloudflare Turnstile (Plano 4b) — proteção anti-bot no formulário de contato.
# Widget client em `src/components/forms/Turnstile.tsx`, verificação server em
# `src/lib/turnstile.ts` (`verifyTurnstile`). As chaves abaixo são as chaves de
# TESTE oficiais da Cloudflare (documentadas em developers.cloudflare.com/
# turnstile/troubleshooting/testing) — SEMPRE passam, não fazem nenhuma
# checagem real. Use-as em dev/preview.
#
# Em PRODUÇÃO: crie um site em dash.cloudflare.com → Turnstile → Add site e
# troque as duas variáveis abaixo pelas chaves reais (site key + secret key)
# geradas lá.
#
# NEXT_PUBLIC_TURNSTILE_SITE_KEY → pública (vai pro bundle client, é isso que
#   o widget usa pra saber qual site renderizar — não é sensível).
# TURNSTILE_SECRET_KEY → sensível, usada só no server (`verifyTurnstile`) pra
#   chamar o endpoint `siteverify` da Cloudflare. Sem essa variável,
#   `verifyTurnstile` falha fechado (retorna `false`) em vez de lançar.
NEXT_PUBLIC_TURNSTILE_SITE_KEY=1x00000000000000000000AA
TURNSTILE_SECRET_KEY=1x0000000000000000000000000000000AA
